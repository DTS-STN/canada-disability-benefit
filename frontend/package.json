{
  "$schema": "https://json.schemastore.org/package",
  "name": "cdb-frontend",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0",
    "npm": ">=10.0"
  },
  "scripts": {
    "build": "npm run build:application && npm run build:server",
    "build:application": "react-router build",
    "build:server": "vite build --config ./vite.server.config.ts",
    "dev": "nodemon --config ./nodemon.json",
    "preview": "npm run build && cross-env NODE_ENV=production SESSION_COOKIE_SECURE=false node --env-file-if-exists=./.env --import ./build/server/telemetry.js ./build/server/server.js",
    "start": "cross-env NODE_ENV=production node --import ./build/server/telemetry.js ./build/server/server.js",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e-update-snapshots": "playwright test --update-snapshots",
    "format:check": "prettier --cache --cache-location ./node_modules/.cache/prettier/ --check ./",
    "format:write": "prettier --cache --cache-location ./node_modules/.cache/prettier/ --write ./",
    "lint:check": "eslint --cache --cache-location: ./node_modules/.cache/eslint/ ./",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "@date-fns/utc": "^2.1.1",
    "@dts-stn/invariant": "^1.0.0",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/otlp-exporter-base": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.0.1",
    "@opentelemetry/semantic-conventions": "^1.34.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@react-router/express": "^7.13.2",
    "@react-router/node": "^7.13.2",
    "@react-router/serve": "^7.13.2",
    "@types/react-router": "^5.1.20",
    "clsx": "^2.1.1",
    "compression": "^1.8.0",
    "connect-redis": "^8.1.0",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "express-session": "^1.19.0",
    "i18next": "^25.10.5",
    "i18next-fetch-backend": "^6.0.0",
    "ioredis": "^5.10.1",
    "isbot": "^5.1.37",
    "jose": "^6.2.2",
    "minimatch": "^10.2.5",
    "moderndash": "^4.0.2",
    "morgan": "^1.10.0",
    "oauth4webapi": "^3.8.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^15.5.3",
    "react-idle-timer": "^5.7.3",
    "react-router": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "undici": "^7.24.5",
    "valibot": "^1.1.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-error-format": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.53.0",
    "@react-router/dev": "^7.13.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/compression": "^1.8.1",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.15.32",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^3.2.3",
    "eslint": "^9.29.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "jsdom": "^29.0.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.8",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.4.2",
    "vite-plugin-static-copy": "^3.1.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.1.4",
    "vitest-mock-extended": "^3.1.0"
  }
}
